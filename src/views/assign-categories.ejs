<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <p><strong>Project:</strong> <%= project.title %></p>

    <form action="/project/<%= project.project_id %>/assign-categories" method="POST" class="form-card">
        <% if (allCategories && allCategories.length > 0) { %>
            <div class="form-group">
                <p><strong>Select categories for this project:</strong></p>
                <div class="checkbox-list">
                    <% allCategories.forEach(category => { %>
                        <%
                            const isChecked = assignedCategories.some(
                                ac => ac.category_id === category.category_id
                            );
                        %>
                        <label class="checkbox-label">
                            <input
                                type="checkbox"
                                name="categories"
                                value="<%= category.category_id %>"
                                <%= isChecked ? 'checked' : '' %>
                            />
                            <%= category.name %>
                        </label>
                    <% }); %>
                </div>
            </div>
        <% } else { %>
            <p>No categories available. Please add categories first.</p>
        <% } %>

        <div class="form-actions">
            <button type="submit" class="btn">Save Categories</button>
            <a href="/project/<%= project.project_id %>" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>
<%- include('partials/footer') %>
